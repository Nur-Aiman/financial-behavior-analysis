{
  "name": "fba-backend",
  "version": "1.0.0",
  "description": "Financial Behavior Intelligent Analysis Backend",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:migrate": "knex migrate:latest --env development",
    "db:migrate:make": "knex migrate:make",
    "db:seed": "knex seed:run --env development",
    "db:seed:make": "knex seed:make",
    "db:rollback": "knex migrate:rollback --env development",
    "db:reset": "knex migrate:rollback --all --env development && knex migrate:latest --env development && knex seed:run --env development"
  },
  "keywords": [
    "finance",
    "budget",
    "forecasting"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "decimal.js": "^10.4.3",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "knex": "^3.1.0",
    "pg": "^8.11.3",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "jest": "^29.5.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  },
  "directories": {
    "test": "tests"
  }
}
