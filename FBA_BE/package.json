{
  "name": "fba-backend",
  "version": "1.0.0",
  "description": "Financial Behavior Intelligent Analysis Backend",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon",
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "tsc --noEmit",
    "db:migrate": "knex migrate:latest --env development",
    "db:migrate:make": "knex migrate:make",
    "db:seed": "knex seed:run --env development",
    "db:seed:make": "knex seed:make",
    "db:rollback": "knex migrate:rollback --env development",
    "db:reset": "knex migrate:rollback --all --env development && knex migrate:latest --env development && knex seed:run --env development"
  },
  "keywords": [
    "finance",
    "budget",
    "forecasting"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "decimal.js": "^10.4.3",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "knex": "^3.1.0",
    "pg": "^8.11.3",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^2.0.12",
    "@types/uuid": "^9.0.2",
    "jest": "^29.5.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0"
  }
}
